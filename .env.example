# Credenciais usadas pelos jobs. NUNCA versione valores reais.
# Copie para .env (gitignored) e preencha, ou exporte no seu shell:
#
#   set -a; source .env; set +a
#   python3 browser.py -s job0
#
# Os run.py de cada job leem estas variaveis via os.environ e as injetam
# em runtime (pre_action). Sem elas, os campos de login ficam vazios.

# job0  -> exemplo.com
EXEMPLO_EMAIL=
EXEMPLO_PASSWORD=

# job1, job2  -> conta Google/Gmail
GMAIL_EMAIL=
GMAIL_PASSWORD=

# job3, job4  -> admin painel.exemplo.com
PAINEL_EMAIL=
PAINEL_PASSWORD=
